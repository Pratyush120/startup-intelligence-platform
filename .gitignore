# =========================================================================
# Strategic Decision Intelligence Platform (SDIP) - .gitignore
# =========================================================================

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.venv/
venv/
env/

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
htmlcov/
dist/
build/
*.egg-info/

# Next.js / React
/.next/
/out/
/build
.vercel/

# Database & Data
*.db
*.sqlite
*.sqlite3
/data/*.db
/startup_intelligence.db

# Environments
.env
.env.*
!.env.example
.env.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# IDE / OS
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# Typescript
*.tsbuildinfo
next-env.d.ts

# Misc
coverage/
*.pem